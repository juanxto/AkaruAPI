@baseUrl = http://localhost:5001
@token = {{login.response.body.token}}

### Health check
GET {{baseUrl}}/health

### 1. Cadastro
# @name register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "nome": "Juan Pablo",
  "email": "juan@akaru.local",
  "senha": "senha123"
}

### 2. Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "juan@akaru.local",
  "senha": "senha123"
}

### 3. Perfil do usuário logado
GET {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{token}}

### 4. Atualizar perfil
PUT {{baseUrl}}/api/usuarios/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nome": "Juan Pablo",
  "cidade": "São Paulo",
  "estado": "SP",
  "latitude": -23.5505,
  "longitude": -46.6333
}

### 5. Registrar plantio
POST {{baseUrl}}/api/plantios
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "culturaId": 3,
  "latitude": -23.5505,
  "longitude": -46.6333,
  "dataPlantio": "2026-06-15T00:00:00Z",
  "detalhes": "Solo argiloso, 2 hectares",
  "cidade": "São Paulo",
  "estado": "SP"
}

### 6. Listar plantios
GET {{baseUrl}}/api/plantios
Authorization: Bearer {{token}}

### 7. Salvar histórico
POST {{baseUrl}}/api/historico
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "culturaId": 3,
  "culturaNome": "Milho",
  "textoRecomendacao": "Plante entre setembro e novembro. Solo bem drenado.",
  "score": 87.5,
  "latitude": -23.5505,
  "longitude": -46.6333,
  "detalhes": "Área irrigada",
  "dadosClimaticos": "{\"temperatura\":28,\"umidade\":65}"
}

### 8. Listar histórico
GET {{baseUrl}}/api/historico
Authorization: Bearer {{token}}
